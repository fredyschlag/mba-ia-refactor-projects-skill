# Chave usada para assinar sessões Flask e tokens JWT. Gere um valor aleatório forte
# (ex: python -c "import secrets; print(secrets.token_hex(32))") — nunca reutilize este exemplo.
SECRET_KEY=

# true/false — nunca "true" em produção (habilita o debugger interativo do Werkzeug).
DEBUG=false

# Caminho do arquivo SQLite.
DB_PATH=loja.db

# Horas de validade do token JWT emitido no login.
JWT_EXPIRATION_HOURS=24
